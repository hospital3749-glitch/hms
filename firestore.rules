rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isDoctor() {
      return isSignedIn() && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if true; 
      allow write: if adminId == 'default_admin'; // Allow initialization
    }

    // Doctors collection
    match /doctors/{doctorId} {
      allow read: if true; // Allow login and listing
      allow write: if true; // In this specific custom system, allow admin/doctors to manage
    }

    // Patients collection
    match /patients/{patientId} {
      allow read, write: if true; 
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }

    // Wards collection
    match /wards/{wardId} {
      allow read, write: if true;
    }
  }
}
